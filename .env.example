# TipStream SDK Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
TIPSTREAM_API_KEY=your_api_key_here
TIPSTREAM_API_URL=https://api.tipstream.example.com

# Security Configuration
SIGNING_SECRET=your_signing_secret_here
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Metrics Configuration
METRICS_ENABLED=true
METRICS_WEBHOOK_URL=https://your-webhook-endpoint.com/metrics

# NPM Metrics (for tracking downloads)
NPM_REGISTRY_URL=https://registry.npmjs.org

# Development
NODE_ENV=development
DEBUG=tipstream:*
